{
  "name": "oxc-walker",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "repository": "oxc-project/oxc-walker",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.mjs"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "vp test dev",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "prepare": "simple-git-hooks",
    "prepack": "pnpm build",
    "prepublishOnly": "pnpm lint && pnpm test",
    "test": "pnpm test:unit && pnpm test:types",
    "test:unit": "vp test",
    "test:types": "tsc --noEmit"
  },
  "dependencies": {
    "magic-regexp": "^0.11.0"
  },
  "devDependencies": {
    "@types/node": "24.10.3",
    "@vitest/coverage-v8": "4.1.6",
    "knip": "^6.0.0",
    "lint-staged": "16.4.0",
    "oxc-parser": "0.131.0",
    "simple-git-hooks": "2.13.1",
    "typescript": "6.0.3",
    "unbuild": "3.6.1",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "oxc-parser": ">=0.98.0",
    "rolldown": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "oxc-parser": {
      "optional": true
    },
    "rolldown": {
      "optional": true
    }
  },
  "resolutions": {
    "oxc-walker": "link:."
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": [
      "vp fmt --no-error-on-unmatched-pattern"
    ],
    "*.{js,ts,mjs,cjs}": [
      "vp lint --fix"
    ]
  },
  "packageManager": "pnpm@11.0.4"
}
